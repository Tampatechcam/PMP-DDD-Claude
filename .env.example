# Public — exposed to the browser, baked in at build time
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site origin for magic-link / invite redirects (Vercel, Netlify, local).
# Netlify: https://your-site.netlify.app — also allow .../callback in Supabase Auth.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — NEVER prefix with NEXT_PUBLIC. Mark sensitive on Vercel/Netlify.
SUPABASE_SERVICE_ROLE_KEY=

# Used by scripts/db:types and the Supabase CLI
SUPABASE_PROJECT_REF=

# Set to "true" to show demo login buttons (dev only; default off).
DEMO_AUTH_ENABLED=

# --- Vercel Marketplace integrations (auto-provisioned via `vercel integration add`) ---

# Sentry — error monitoring + source maps
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Axiom — app logs + Vercel log/trace drains
NEXT_PUBLIC_AXIOM_DATASET=
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_INGEST_ENDPOINT=

# Upstash Redis — rate limiting / cache
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Resend — transactional email (custom; Supabase Auth handles invites)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Automatic Sheet→DB sync (netlify/functions/sync-dm-sheet.mts, @hourly) ---
# Published-to-web CSV URL of the Direct Mail sheet. Until this is set on
# Netlify, the scheduled sync no-ops (logs and exits).
#   Google Sheets → File → Share → Publish to web → the DM tab → CSV → copy URL.
# NOTE: a published CSV is readable by anyone with the link, and the sheet
# contains client PII (names/addresses/phones). For a private alternative,
# switch the function to a Google service-account read instead of publishing.
DM_SHEET_CSV_URL=

# --- Supabase → Direct Mail sheet MIRROR (netlify/functions/mirror-orders-to-sheet.mts, every 15 min) ---
# Append-only push of Supabase orders into the Direct Mail sheet (reverse of
# sync-dm-sheet). Needs a Google service account shared as Editor on the sheet,
# with the Google Sheets API enabled. Keep sync-dm-sheet OFF if Supabase is the
# source of truth, or the two directions fight.
GOOGLE_SA_KEY=          # full service-account JSON, as one value (secret)
DM_SHEET_ID=            # Direct Mail sheet id
MAIN_SHEET_ID=          # MAIN sheet id (reserved — MAIN mirroring is a follow-up)
MIRROR_LIVE=            # "true" to actually write; unset / anything else = dry-run
MAX_APPEND=             # optional per-run cap on appended rows (default 25)
