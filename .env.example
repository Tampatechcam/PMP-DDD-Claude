# Public — exposed to the browser, baked in at build time
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth redirect fallback when Host header is unavailable (optional locally).
# Also add this origin + /callback in Supabase → Auth → Redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — NEVER prefix with NEXT_PUBLIC. Mark "Sensitive" in Vercel.
SUPABASE_SERVICE_ROLE_KEY=

# Used by scripts/db:types and the Supabase CLI
SUPABASE_PROJECT_REF=

# Set to "true" to show demo login buttons (dev only; default off).
DEMO_AUTH_ENABLED=
