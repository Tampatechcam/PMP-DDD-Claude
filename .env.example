# Public — exposed to the browser, baked in at build time
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Site origin for magic-link / invite redirects (Vercel, Netlify, local).
# Netlify: https://your-site.netlify.app — also allow .../callback in Supabase Auth.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — NEVER prefix with NEXT_PUBLIC. Mark sensitive on Vercel/Netlify.
SUPABASE_SERVICE_ROLE_KEY=

# Used by scripts/db:types and the Supabase CLI
SUPABASE_PROJECT_REF=

# Set to "true" to show demo login buttons (dev only; default off).
DEMO_AUTH_ENABLED=

# --- Vercel Marketplace integrations (auto-provisioned via `vercel integration add`) ---

# Sentry — error monitoring + source maps
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Axiom — app logs + Vercel log/trace drains
NEXT_PUBLIC_AXIOM_DATASET=
NEXT_PUBLIC_AXIOM_TOKEN=
NEXT_PUBLIC_AXIOM_INGEST_ENDPOINT=

# Upstash Redis — rate limiting / cache
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# Resend — transactional email (custom; Supabase Auth handles invites)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
