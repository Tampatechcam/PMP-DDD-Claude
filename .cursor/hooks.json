{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/before-shell-guard.mjs",
        "failClosed": true,
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/after-file-edit.mjs",
        "timeout": 10
      }
    ]
  }
}
